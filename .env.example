# Copy to .env in the repo root for docker compose. Never commit .env.
# Before pushing: ./scripts/audit-repo-secrets.sh
# Generate strong values, e.g. openssl rand -hex 32

POSTGRES_USER=devops
POSTGRES_PASSWORD=123123123
POSTGRES_DB=devopscanvas

# Required by the API (JWT signing). Must be long and random in any shared environment.
JWT_SECRET=12312312312312312312312312312312

# Optional: only used when Supabase/GoTrue JWT is not set on the canvas node.
# DEVOPS_CANVAS_GOTRUE_JWT_SECRET=

# Optional: local dev only — MinIO translator will not invent a password if unset.
# DEVOPS_CANVAS_DEFAULT_MINIO_PASSWORD=

# SaaS API (cmd/saas-api): comma-separated browser origins for CORS.
# CORS_ALLOWED_ORIGINS=https://your-app.example,http://localhost:3000

# Public URL of the web app (no trailing slash). Team invite links must match how users open the UI.
# Examples: http://localhost:3000  or  http://YOUR_SERVER_IP:3000  on a VM/bastion.
# APP_BASE_URL=http://localhost:3000
